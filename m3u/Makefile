all: MKM3U MKINDEX

MKINDEX: MKM3U.b64 MKINDEX.m4 TOINDEX.b64
	openssl base64 < TOINDEX > TOINDEX.b64
	m4 MKINDEX.m4 > MKINDEX

MKM3U: MKM3U.m4 MK3HELP.b64
	m4 MKM3U.m4 > MKM3U

MK3HELP.b64: MK3HELP
	openssl base64 < MK3HELP > MK3HELP.b64

TOINDEX.b64: TOINDEX
	openssl base64 < TOINDEX > TOINDEX.b64

MKM3U.b64: MKM3U
	openssl base64 < MKM3U > MKM3U.b64

clean:
	rm -f *b64 MKINDEX
